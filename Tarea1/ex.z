// ==========================================
// EJERCICIO 1: Leyes de De Morgan
// ==========================================

de_morgan1 = \P Q -> not (P and Q) == (not P or not Q)
de_morgan2 = \P Q -> not (P or Q) == (not P and not Q)

// ==========================================
// EJERCICIO 2: Función Sucesor
// ==========================================

succ = \z -> z + 1
